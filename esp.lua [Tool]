----------------------------------------------------------------
-- Утилиты
----------------------------------------------------------------
local function formatValue(value)
	local t = typeof(value)
	if t == "string" then
		return '"' .. value .. '"'
	elseif t == "boolean" then
		return value and "true" or "false"
	elseif t == "number" then
		return tostring(value)
	elseif t == "EnumItem" then
		return tostring(value)
	elseif t == "BrickColor" then
		return tostring(value)
	elseif t == "Color3" then
		return string.format("%d, %d, %d", math.round(value.R * 255), math.round(value.G * 255), math.round(value.B * 255))
	elseif t == "Vector3" then
		return string.format("%.2f, %.2f, %.2f", value.X, value.Y, value.Z)
	elseif t == "CFrame" then
		local p = value.Position
		return string.format("%.1f, %.1f, %.1f", p.X, p.Y, p.Z)
	elseif t == "Instance" then
		return value and value.Name or "nil"
	elseif t == "table" then
		return "{table}"
	else
		return tostring(value)
	end
end

local function getToolProperties(tool)
	local props = {}

	-- Основные свойства Tool
	local toolProps = {
		"Name", "ClassName", "Archivable", "CanBeDropped",
		"Enabled", "Grip", "GripForward", "GripRight",
		"GripUp", "GripPos", "ManualActivationOnly",
		"RequiresHandle", "ToolTip",
	}

	for _, propName in toolProps do
		local ok, value = pcall(function() return tool[propName] end)
		if ok then
			table.insert(props, {name = propName, value = value, category = "Tool"})
		end
	end

	-- Объекты внутри Tool
	local children = tool:GetChildren()
	table.sort(children, function(a, b) return a.Name:lower() < b.Name:lower() end)
	for _, child in children do
		table.insert(props, {
			name = child.Name,
			value = child.ClassName,
			category = "Children",
			isChild = true,
		})
	end

	-- Атрибуты
	local attrs = tool:GetAttributes()
	local attrNames = {}
	for name, _ in attrs do
		table.insert(attrNames, name)
	end
	table.sort(attrNames)
	for _, name in attrNames do
		table.insert(props, {name = name, value = attrs[name], category = "Attributes"})
	end

	-- Теги
	local tags = tool:GetTags()
	if #tags > 0 then
		table.sort(tags)
		table.insert(props, {name = "Tags", value = table.concat(tags, ", "), category = "Attributes"})
	end

	-- Описание (если есть атрибут Description)
	local desc = tool:GetAttribute("Description")
	if desc then
		table.insert(props, {name = "Description", value = desc, category = "Info", isDescription = true})
	end

	return props
end

----------------------------------------------------------------
-- Создание GUI
----------------------------------------------------------------
local function createPropertyRow(name, value, isCategory, isChild, isDescription, index)
	local row = Instance.new("Frame")
	row.Name = "Row_" .. name
	row.BackgroundColor3 = (index % 2 == 0) and ROW_EVEN or ROW_ODD
	row.BorderSizePixel = 0
	row.Size = UDim2.new(1, 0, 0, ENTRY_HEIGHT)
	row.AutomaticSize = Enum.AutomaticSize.None

	if isCategory then
		row.BackgroundColor3 = HEADER_COLOR

		local label = Instance.new("TextLabel")
		label.Name = "CategoryLabel"
		label.BackgroundTransparency = 1
		label.Size = UDim2.new(1, -PADDING * 2, 1, 0)
		label.Position = UDim2.new(0, PADDING, 0, 0)
		label.Font = FONT
		label.TextSize = FONT_SIZE
		label.TextColor3 = CATEGORY_COLOR
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.Text = "  " .. name
		label.Parent = row

		local separator = Instance.new("Frame")
		separator.Name = "Separator"
		separator.Size = UDim2.new(1, 0, 0, 1)
		separator.Position = UDim2.new(0, 0, 1, -1)
		separator.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
		separator.BorderSizePixel = 0
		separator.Parent = row
	else
		-- Разделитель колонок
		local divider = Instance.new("Frame")
		divider.Name = "Divider"
		divider.Size = UDim2.new(0, 1, 1, 0)
		divider.Position = UDim2.new(PROPERTY_NAME_WIDTH, 0, 0, 0)
		divider.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
		divider.BorderSizePixel = 0
		divider.Parent = row

		-- Имя свойства
		local nameLabel = Instance.new("TextLabel")
		nameLabel.Name = "NameLabel"
		nameLabel.BackgroundTransparency = 1
		nameLabel.Size = UDim2.new(PROPERTY_NAME_WIDTH, -PADDING * 2, 1, 0)
		nameLabel.Position = UDim2.new(0, PADDING, 0, 0)
		nameLabel.Font = FONT
		nameLabel.TextSize = FONT_SIZE
		nameLabel.TextColor3 = isChild and ACCENT or TEXT_COLOR
		nameLabel.TextXAlignment = Enum.TextXAlignment.Left
		nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
		nameLabel.Text = name
		nameLabel.Parent = row

		-- Значение свойства
		local valueLabel = Instance.new("TextLabel")
		valueLabel.Name = "ValueLabel"
		valueLabel.BackgroundTransparency = 1
		valueLabel.Size = UDim2.new(1 - PROPERTY_NAME_WIDTH, -PADDING * 2, 1, 0)
		valueLabel.Position = UDim2.new(PROPERTY_NAME_WIDTH, PADDING, 0, 0)
		valueLabel.Font = FONT
		valueLabel.TextSize = FONT_SIZE
		valueLabel.TextColor3 = isDescription and Color3.fromRGB(180, 220, 180) or Color3.fromRGB(255, 200, 100)
		valueLabel.TextXAlignment = Enum.TextXAlignment.Left
		valueLabel.TextTruncate = Enum.TextTruncate.AtEnd
		valueLabel.Text = formatValue(value)
		valueLabel.Parent = row

		-- Цветной индикатор для Color3
		if typeof(value) == "Color3" then
			local swatch = Instance.new("Frame")
			swatch.Name = "ColorSwatch"
			swatch.Size = UDim2.new(0, 14, 0, 14)
			swatch.Position = UDim2.new(1 - PROPERTY_NAME_WIDTH, PADDING, 0.5, -7)
			swatch.BackgroundColor3 = value
			swatch.BorderSizePixel = 1
			swatch.BorderColor3 = Color3.fromRGB(80, 80, 80)
			local corner = Instance.new("UICorner")
			corner.CornerRadius = UDim.new(0, 3)
			corner.Parent = swatch
			swatch.Parent = row
			valueLabel.Size = UDim2.new(1 - PROPERTY_NAME_WIDTH, -PADDING * 2 - 20, 1, 0)
		end

		-- Иконка для дочерних объектов
		if isChild then
			local icon = Instance.new("ImageLabel")
			icon.Name = "ChildIcon"
			icon.Size = UDim2.new(0, 14, 0, 14)
			icon.Position = UDim2.new(0, PADDING, 0.5, -7)
			icon.BackgroundTransparency = 1
			icon.Image = "rbxassetid://6305984390"
			icon.ImageColor3 = ACCENT
			icon.Parent = row
			nameLabel.Position = UDim2.new(0, PADDING + 18, 0, 0)
			nameLabel.Size = UDim2.new(PROPERTY_NAME_WIDTH, -PADDING * 2 - 18, 1, 0)
		end
	end

	return row
end

local function buildToolInfoGui(tool)
	-- ScreenGui
	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "ToolInfoGui"
	screenGui.ResetOnSpawn = false
	screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	screenGui.IgnoreGuiInset = true

	-- Главная рамка (окно)
	local mainFrame = Instance.new("Frame")
	mainFrame.Name = "MainFrame"
	mainFrame.Size = UDim2.new(WINDOW_WIDTH_SCALE, 0, WINDOW_HEIGHT_SCALE, 0)
	mainFrame.Position = UDim2.new(1 - WINDOW_WIDTH_SCALE - 0.01, 0, 0.08, 0)
	mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	mainFrame.BorderSizePixel = 0
	mainFrame.Parent = screenGui

	local mainCorner = Instance.new("UICorner")
	mainCorner.CornerRadius = UDim.new(0, 6)
	mainCorner.Parent = mainFrame

	local stroke = Instance.new("UIStroke")
	stroke.Color = Color3.fromRGB(60, 60, 60)
	stroke.Thickness = 1
	stroke.Parent = mainFrame

	-- Заголовок (перетаскиваемый)
	local header = Instance.new("Frame")
	header.Name = "Header"
	header.Size = UDim2.new(1, 0, 0, 32)
	header.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
	header.BorderSizePixel = 0
	header.Parent = mainFrame

	local headerCorner = Instance.new("UICorner")
	headerCorner.CornerRadius = UDim.new(0, 6)
	headerCorner.Parent = header

	-- Скрываем нижние скругления заголовка
	local headerFix = Instance.new("Frame")
	headerFix.Size = UDim2.new(1, 0, 0, 10)
	headerFix.Position = UDim2.new(0, 0, 1, -10)
	headerFix.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
	headerFix.BorderSizePixel = 0
	headerFix.Parent = header

	local iconLabel = Instance.new("ImageLabel")
	iconLabel.Name = "ToolIcon"
	iconLabel.Size = UDim2.new(0, 18, 0, 18)
	iconLabel.Position = UDim2.new(0, 8, 0.5, -9)
	iconLabel.BackgroundTransparency = 1
	iconLabel.Image = "rbxassetid://6305984390"
	iconLabel.ImageColor3 = ACCENT
	iconLabel.Parent = header

	local titleLabel = Instance.new("TextLabel")
	titleLabel.Name = "Title"
	titleLabel.BackgroundTransparency = 1
	titleLabel.Size = UDim2.new(1, -70, 1, 0)
	titleLabel.Position = UDim2.new(0, 30, 0, 0)
	titleLabel.Font = Enum.Font.GothamBold
	titleLabel.TextSize = 14
	titleLabel.TextColor3 = Color3.fromRGB(230, 230, 230)
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.Text = tool.Name
	titleLabel.Parent = header

	-- Кнопка закрытия
	local closeBtn = Instance.new("TextButton")
	closeBtn.Name = "CloseButton"
	closeBtn.Size = UDim2.new(0, 24, 0, 24)
	closeBtn.Position = UDim2.new(1, -30, 0.5, -12)
	closeBtn.BackgroundColor3 = Color3.fromRGB(180, 60, 60)
	closeBtn.Text = "X"
	closeBtn.Font = Enum.Font.GothamBold
	closeBtn.TextSize = 12
	closeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	closeBtn.BorderSizePixel = 0
	local closeCorner = Instance.new("UICorner")
	closeCorner.CornerRadius = UDim.new(0, 4)
	closeCorner.Parent = closeBtn
	closeBtn.Parent = header

	-- Контейнер для ScrollingFrame
	local contentContainer = Instance.new("Frame")
	contentContainer.Name = "ContentContainer"
	contentContainer.Size = UDim2.new(1, 0, 1, -32)
	contentContainer.Position = UDim2.new(0, 0, 0, 32)
	contentContainer.BackgroundTransparency = 1
	contentContainer.ClipsDescendants = true
	local containerCorner = Instance.new("UICorner")
	containerCorner.CornerRadius = UDim.new(0, 6)
	containerCorner.Parent = contentContainer
	contentContainer.Parent = mainFrame

	-- ScrollingFrame
	local scrollFrame = Instance.new("ScrollingFrame")
	scrollFrame.Name = "PropertyScroll"
	scrollFrame.Size = UDim2.new(1, 0, 1, 0)
	scrollFrame.Position = UDim2.new(0, 0, 0, 0)
	scrollFrame.BackgroundTransparency = 1
	scrollFrame.BorderSizePixel = 0
	scrollFrame.ScrollBarThickness = 6
	scrollFrame.ScrollBarImageColor3 = Color3.fromRGB(100, 100, 100)
	scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
	scrollFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
	scrollFrame.Parent = contentContainer

	local layout = Instance.new("UIListLayout")
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Padding = UDim.new(0, 0)
	layout.Parent = scrollFrame

	-- Заполняем свойства
	local properties = getToolProperties(tool)
	local currentCategory = ""
	local rowIndex = 0
	local order = 0

	for _, prop in properties do
		if prop.category ~= currentCategory then
			currentCategory = prop.category
			local catRow = createPropertyRow(currentCategory, nil, true, false, false, rowIndex)
			catRow.LayoutOrder = order
			catRow.Parent = scrollFrame
			order += 1
			rowIndex += 1
		end

		local row = createPropertyRow(prop.name, prop.value, false, prop.isChild, prop.isDescription, rowIndex)
		row.LayoutOrder = order
		row.Parent = scrollFrame
		order += 1
		rowIndex += 1
	end

	-- Перетаскивание
	local UserInputService = game:GetService("UserInputService")
	local dragging = false
	local dragStart = nil
	local startPos = nil

	header.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = mainFrame.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			mainFrame.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
		end
	end)

	-- Закрытие
	closeBtn.MouseButton1Click:Connect(function()
		screenGui:Destroy()
	end)

	return screenGui
end

----------------------------------------------------------------
-- Отслеживание Tool в руках
----------------------------------------------------------------
local currentGui = nil

local function onCharacterAdded(character)
	local function onChildChanged(child)
		if child:IsA("Tool") then
			if child.Parent == character then
				-- Tool экипирован
				if currentGui then
					currentGui:Destroy()
					currentGui = nil
				end
				currentGui = buildToolInfoGui(child)
				currentGui.Parent = playerGui
			end
		end
	end

	-- Отслеживаем экипировку (Tool добавляется в character)
	character.ChildAdded:Connect(function(child)
		if child:IsA("Tool") then
			if currentGui then
				currentGui:Destroy()
					currentGui = nil
				end
			currentGui = buildToolInfoGui(child)
				currentGui.Parent = playerGui

			-- Отслеживаем снятие этого Tool
			local toolRef = child
			child.AncestryChanged:Connect(function(_, newParent)
				if newParent ~= character and currentGui then
					currentGui:Destroy()
					currentGui = nil
				end
			end)
		end
	end)

	-- Если Tool уже в руках при спавне
	for _, child in character:GetChildren() do
		if child:IsA("Tool") then
			if currentGui then
				currentGui:Destroy()
				currentGui = nil
				end
			currentGui = buildToolInfoGui(child)
				currentGui.Parent = playerGui

			child.AncestryChanged:Connect(function(_, newParent)
				if newParent ~= character and currentGui then
					currentGui:Destroy()
					currentGui = nil
				end
			end)
			break
		end
	end
end

if player.Character then
	task.spawn(onCharacterAdded, player.Character)
end
player.CharacterAdded:Connect(onCharacterAdded)
