-- ===== Helper Functions =====
local function formatValue(value)
	if value == nil then
		return "nil"
	elseif typeof(value) == "string" then
		return '"' .. value .. '"'
	elseif typeof(value) == "boolean" then
		return value and "true" or "false"
	elseif typeof(value) == "number" then
		if math.abs(value - math.round(value)) < 0.001 then
			return tostring(math.round(value))
		end
		return string.format("%.3f", value)
	elseif typeof(value) == "Color3" then
		return string.format("%d, %d, %d", math.round(value.R * 255), math.round(value.G * 255), math.round(value.B * 255))
	elseif typeof(value) == "Vector3" then
		return string.format("%.1f, %.1f, %.1f", value.X, value.Y, value.Z)
	elseif typeof(value) == "CFrame" then
		local pos = value.Position
		return string.format("%.1f, %.1f, %.1f", pos.X, pos.Y, pos.Z)
	elseif typeof(value) == "EnumItem" then
		return tostring(value)
	elseif typeof(value) == "BrickColor" then
		return value.Name
	elseif typeof(value) == "Instance" then
		return value.Name
	else
		return tostring(value)
	end
end

local function createSectionLabel(text, order)
	local label = Instance.new("TextLabel")
	label.Name = "Section_" .. text
	label.Size = UDim2.new(1, 0, 0, 24)
	label.BackgroundTransparency = 1
	label.Text = "  " .. text:upper()
	label.TextColor3 = Color3.fromRGB(180, 180, 180)
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Font = Enum.Font.GothamBold
	label.TextSize = 11
	label.LayoutOrder = order
	label.Parent = mainFrame

	local bg = Instance.new("Frame")
	bg.Size = UDim2.new(1, 0, 1, 0)
	bg.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
	bg.BorderSizePixel = 0
	bg.ZIndex = label.ZIndex - 1
	bg.Parent = label

	return label
end

local function createPropertyRow(propName, propValue, order, valueColor)
	local row = Instance.new("Frame")
	row.Name = "Prop_" .. propName
	row.Size = UDim2.new(1, 0, 0, 22)
	row.BackgroundTransparency = 1
	row.LayoutOrder = order
	row.Parent = mainFrame

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Name = "Name"
	nameLabel.Size = UDim2.new(0.45, 0, 1, 0)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text = "  " .. propName
	nameLabel.TextColor3 = Color3.fromRGB(160, 160, 160)
	nameLabel.TextXAlignment = Enum.TextXAlignment.Left
	nameLabel.Font = Enum.Font.Gotham
	nameLabel.TextSize = 12
	nameLabel.Parent = row

	local valueLabel = Instance.new("TextLabel")
	valueLabel.Name = "Value"
	valueLabel.Size = UDim2.new(0.55, -4, 1, 0)
	valueLabel.Position = UDim2.new(0.45, 4, 0, 0)
	valueLabel.BackgroundTransparency = 1
	valueLabel.Text = formatValue(propValue)
	valueLabel.TextColor3 = valueColor or Color3.fromRGB(220, 220, 220)
	valueLabel.TextXAlignment = Enum.TextXAlignment.Right
	valueLabel.Font = Enum.Font.Gotham
	valueLabel.TextSize = 12
	valueLabel.Parent = row

	return row, valueLabel
end

