-- ===== Tool Properties Display =====
local VALUE_COLORS = {
	string = Color3.fromRGB(170, 210, 255),
	boolean = Color3.fromRGB(255, 180, 100),
	number = Color3.fromRGB(180, 255, 180),
	Color3 = Color3.fromRGB(255, 150, 150),
	Vector3 = Color3.fromRGB(255, 255, 150),
	CFrame = Color3.fromRGB(255, 255, 150),
	EnumItem = Color3.fromRGB(200, 180, 255),
	BrickColor = Color3.fromRGB(255, 150, 150),
}

local TOOL_PROPERTIES = {
	"ToolTip", "CanBeDropped", "Enabled", "RequiresHandle",
	"CanCarryItem", "GripForward", "GripRight", "GripUp", "GripPos",
}

local function clearPanel()
	for _, child in mainFrame:GetChildren() do
		if child:IsA("GuiObject") then
			child:Destroy()
		end
	end
end

local function showToolInfo(tool)
	clearPanel()
	mainFrame.Visible = true

	local order = 0

	-- Tool Name Header
	local header = Instance.new("TextLabel")
	header.Name = "Header"
	header.Size = UDim2.new(1, 0, 0, 30)
	header.BackgroundTransparency = 1
	header.Text = tool.Name
	header.TextColor3 = Color3.fromRGB(255, 255, 255)
	header.TextXAlignment = Enum.TextXAlignment.Left
	header.Font = Enum.Font.GothamBold
	header.TextSize = 16
	header.LayoutOrder = order
	header.Parent = mainFrame
	order = order + 1

	-- Description
	local desc = tool:GetAttribute("Description") or tool.ToolTip or ""
	if desc ~= "" then
		local descBox = createDescriptionBox(desc, order)
		order = order + 1
	end

	createSeparator(order)
	order = order + 1

	-- Properties Section
	createSectionLabel("Properties", order)
	order = order + 1

	for _, propName in TOOL_PROPERTIES do
		local success, value = pcall(function()
			return tool[propName]
		end)
		if success and value ~= nil then
			local valueType = typeof(value)
			local color = VALUE_COLORS[valueType] or Color3.fromRGB(220, 220, 220)
			createPropertyRow(propName, value, order, color)
			order = order + 1
		end
	end

	-- Attributes Section
	local attrs = tool:GetAttributes()
	local hasAttrs = false
	for _ in pairs(attrs) do
		hasAttrs = true
		break
	end

	if hasAttrs then
		createSeparator(order)
		order = order + 1

		createSectionLabel("Attributes", order)
		order = order + 1

		for attrName, attrValue in pairs(attrs) do
			local valueType = typeof(attrValue)
			local color = VALUE_COLORS[valueType] or Color3.fromRGB(220, 220, 220)
			createPropertyRow(attrName, attrValue, order, color)
			order = order + 1
		end
	end

	-- Children Section
	local children = tool:GetChildren()
	if #children > 0 then
		createSeparator(order)
		order = order + 1

		createSectionLabel("Children", order)
		order = order + 1

		for _, child in children do
			local childType = child.ClassName
			local displayValue = child.Name .. "  [" .. childType .. "]"
			createPropertyRow(child.Name, displayValue, order, Color3.fromRGB(180, 220, 255))
			order = order + 1
		end
	end

	-- Tags Section
	local tags = tool:GetTags()
	if #tags > 0 then
		createSeparator(order)
		order = order + 1

		createSectionLabel("Tags", order)
		order = order + 1

		for _, tag in tags do
			createPropertyRow("Tag", tag, order, Color3.fromRGB(255, 200, 150))
			order = order + 1
		end
	end
end

local function hideToolInfo()
	mainFrame.Visible = false
	clearPanel()
end

-- ===== Tool Detection =====
local function onCharacterAdded(character)
	character.ChildAdded:Connect(function(child)
		if child:IsA("Tool") then
			showToolInfo(child)

			-- Update when attributes change
			child.AttributeChanged:Connect(function()
				if mainFrame.Visible then
					showToolInfo(child)
				end
			end)

			-- Update when children change
			child.ChildAdded:Connect(function()
				if mainFrame.Visible then
					showToolInfo(child)
				end
			end)
			child.ChildRemoved:Connect(function()
				if mainFrame.Visible then
					showToolInfo(child)
				end
			end)
		end
	end)

	character.ChildRemoved:Connect(function(child)
		if child:IsA("Tool") then
			hideToolInfo()
		end
	end)
end

if player.Character then
	onCharacterAdded(player.Character)
end
player.CharacterAdded:Connect(onCharacterAdded)
