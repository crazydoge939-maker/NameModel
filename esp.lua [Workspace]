
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Создаем основной ScreenGui
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "FolderExplorerGUI"
screenGui.Parent = playerGui

-- Основная панель для объектов
local panel = Instance.new("Frame")
panel.Size = UDim2.new(0.1, 0, 0.28, 0)
panel.Position = UDim2.new(0.01, 0, 0.05, 0)
panel.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
panel.BorderSizePixel = 2
panel.BorderColor3 = Color3.fromRGB(100, 100, 100)
panel.Parent = screenGui
panel.BackgroundTransparency = 0.2

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0.04, 0)
title.Position = UDim2.new(0, 0, 0, 0)
title.BackgroundTransparency = 1
title.Text = "Объекты"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.TextScaled = true
title.Font = Enum.Font.SourceSansBold
title.Parent = panel

local panelScroll = Instance.new("ScrollingFrame")
panelScroll.Name = "PanelScroll"
panelScroll.Size = UDim2.new(1, 0, 0.96, 0)
panelScroll.Position = UDim2.new(0, 0, 0.04, 0)
panelScroll.BackgroundTransparency = 1
panelScroll.BorderSizePixel = 0
panelScroll.ScrollBarThickness = 0
panelScroll.ScrollingDirection = Enum.ScrollingDirection.Y
panelScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
panelScroll.Parent = panel

local uiListLayout = Instance.new("UIListLayout")
uiListLayout.Parent = panelScroll
uiListLayout.SortOrder = Enum.SortOrder.Name
uiListLayout.Padding = UDim.new(0.005, 0)

-- Создаем правую панель для данных выбранного объекта
local contentFrame = Instance.new("Frame")
contentFrame.Size = UDim2.new(0.12, 0, 0.28, 0)
contentFrame.Position = UDim2.new(0.14, 0, 0.05, 0)
contentFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
contentFrame.BorderSizePixel = 2
contentFrame.BorderColor3 = Color3.fromRGB(100, 100, 100)
contentFrame.Parent = screenGui

local scrollFrame = Instance.new("ScrollingFrame")
scrollFrame.Size = UDim2.new(1, 0, 1, 0)
scrollFrame.BackgroundTransparency = 1
scrollFrame.BorderSizePixel = 0
scrollFrame.Parent = contentFrame
scrollFrame.ScrollBarThickness = 6
scrollFrame.ScrollingDirection = Enum.ScrollingDirection.Y
scrollFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y

local contentLayout = Instance.new("UIListLayout")
contentLayout.Parent = scrollFrame
contentLayout.SortOrder = Enum.SortOrder.Name
contentLayout.Padding = UDim.new(0.005, 0)

local currentFolderConnection -- переменная для соединения

local dragging = false
local dragOffset = Vector2.new()

-- Перемещение панели
panel.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragOffset = Vector2.new(input.Position.X - panel.AbsolutePosition.X, input.Position.Y - panel.AbsolutePosition.Y)
	end
end)

panel.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local screenSize = workspace.CurrentCamera.ViewportSize
		local newPosX = (input.Position.X - dragOffset.X) / screenSize.X
		local newPosY = (input.Position.Y - dragOffset.Y) / screenSize.Y
		newPosX = math.clamp(newPosX, 0, 1 - panel.Size.X.Scale)
		newPosY = math.clamp(newPosY, 0, 1 - panel.Size.Y.Scale)
		panel.Position = UDim2.new(newPosX, 0, newPosY, 0)
		contentFrame.Position = UDim2.new(newPosX + panel.Size.X.Scale + 0.01, 0, newPosY, 0)
	end
end)

local function clearContent(frame)
	for _, child in pairs(frame:GetChildren()) do
		if child:IsA("GuiObject") then
			child:Destroy()
		end
	end
end

local function getColorByType(obj)
	if obj:IsA("Part") then
		return Color3.fromRGB(255, 255, 255)
	elseif obj:IsA("MeshPart") then
		return Color3.fromRGB(80, 80, 80)
	elseif obj:IsA("UnionOperation") then
		return Color3.fromRGB(0, 255, 0)
	elseif obj:IsA("Model") then
		return Color3.fromRGB(255, 0, 255)
	elseif obj:IsA("Folder") then
		return Color3.fromRGB(255, 165, 0)
	else
		return Color3.fromRGB(0, 0, 255)
	end
end

local function getLabelTextByType(obj)
	if obj:IsA("Part") then
		return "[Part]"
	elseif obj:IsA("MeshPart") then
		return "[MeshPart]"
	elseif obj:IsA("UnionOperation") then
		return "[Union]"
	elseif obj:IsA("Model") then
		return "[Model]"
	elseif obj:IsA("Folder") then
		return "[Folder]"
	else
		return "[Object]"
	end
end

local function createObjectButton(obj)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, 0, 0.15, 0)
	btn.Text = obj.Name
	btn.BackgroundColor3 = getColorByType(obj)
	btn.TextColor3 = Color3.fromRGB(0, 0, 0)
	btn.TextScaled = true
	btn.Font = Enum.Font.SourceSans
	btn.Parent = panelScroll

	local padding = Instance.new("UIPadding")
	padding.PaddingLeft = UDim.new(0.01, 0)
	padding.PaddingRight = UDim.new(0.01, 0)
	padding.PaddingTop = UDim.new(0.003, 0)
	padding.PaddingBottom = UDim.new(0.003, 0)
	padding.Parent = btn

	btn.MouseButton1Click:Connect(function()
		showObjectContents(obj)
	end)
end

local function showObjectContents(obj)
	if currentFolderConnection then
		currentFolderConnection:Disconnect()
		currentFolderConnection = nil
	end

	clearContent(scrollFrame)

	-- Отображение информации о выбранном объекте
	local infoLabel = Instance.new("TextLabel")
	infoLabel.Size = UDim2.new(1, 0, 0.05, 0)
	infoLabel.Text = "Объект: " .. obj.Name
	infoLabel.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
	infoLabel.TextColor3 = Color3.fromRGB(255,255,255)
	infoLabel.TextScaled = true
	infoLabel.Font = Enum.Font.SourceSansBold
	infoLabel.Parent = scrollFrame

	-- Создаем отображение цвета объекта
	local colorFrame = Instance.new("Frame")
	colorFrame.Size = UDim2.new(1, -4, 0.1, 0)
	colorFrame.Position = UDim2.new(0, 2, 0, 0)
	colorFrame.BackgroundColor3 = getColorByType(obj)
	colorFrame.BorderSizePixel = 1
	colorFrame.BorderColor3 = Color3.fromRGB(100, 100, 100)
	colorFrame.Parent = scrollFrame

	local labelColor = Instance.new("TextLabel")
	labelColor.Size = UDim2.new(1, 0, 1, 0)
	labelColor.BackgroundTransparency = 1
	labelColor.TextColor3 = Color3.fromRGB(255, 255, 255)
	labelColor.TextScaled = true
	labelColor.Font = Enum.Font.SourceSansBold
	labelColor.Text = "Цвет объекта"
	labelColor.Parent = colorFrame

	local colorIndicator = Instance.new("Frame")
	colorIndicator.Size = UDim2.new(0.2, 0, 1, 0)
	colorIndicator.Position = UDim2.new(0.8, -2, 0, 0)
	colorIndicator.BackgroundColor3 = getColorByType(obj)
	colorIndicator.BorderSizePixel = 1
	colorIndicator.BorderColor3 = Color3.fromRGB(255, 255, 255)
	colorIndicator.Parent = colorFrame

	-- Обновлять цвет при изменении объекта (если необходимо)
	local function updateColor()
		local newColor = getColorByType(obj)
		colorFrame.BackgroundColor3 = newColor
		colorIndicator.BackgroundColor3 = newColor
	end

	-- Создаем список дочерних объектов с их цветами
	local function showChildren(obj)
		clearContent(scrollFrame)
		-- Информация о родительском объекте
		local parentLabel = Instance.new("TextLabel")
		parentLabel.Size = UDim2.new(1, 0, 0.05, 0)
		parentLabel.Text = "Дочерние объекты"
		parentLabel.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
		parentLabel.TextColor3 = Color3.fromRGB(255,255,255)
		parentLabel.TextScaled = true
		parentLabel.Font = Enum.Font.SourceSansBold
		parentLabel.Parent = scrollFrame

		-- Обновляем цвет
		updateColor()

		local function addChildEntry(child)
			local childFrame = Instance.new("Frame")
			childFrame.Size = UDim2.new(1, 0, 0.15, 0)
			childFrame.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
			childFrame.Parent = scrollFrame

			local label = Instance.new("TextLabel")
			label.Size = UDim2.new(0.8, 0, 1, 0)
			label.Position = UDim2.new(0, 2, 0, 0)
			label.BackgroundTransparency = 1
			label.TextColor3 = Color3.fromRGB(255,255,255)
			label.TextScaled = true
			label.Font = Enum.Font.SourceSans
			label.Text = child.Name .. " " .. getLabelTextByType(child)
			label.Parent = childFrame

			local colorBox = Instance.new("Frame")
			colorBox.Size = UDim2.new(0.2, -4, 1, 0)
			colorBox.Position = UDim2.new(0.8, 2, 0, 0)
			colorBox.BackgroundColor3 = getColorByType(child)
			colorBox.BorderSizePixel = 1
			colorBox.BorderColor3 = Color3.fromRGB(255,255,255)
			colorBox.Parent = childFrame
		end

		local children = {}
		for _, c in pairs(obj:GetChildren()) do
			table.insert(children, c)
		end

		for _, c in pairs(children) do
			addChildEntry(c)
		end
	end

	showChildren(obj)

	-- Подписка на изменения внутри объекта
	if currentFolderConnection then
		currentFolderConnection:Disconnect()
		currentFolderConnection = nil
	end

	currentFolderConnection = obj.ChildAdded:Connect(function()
		showChildren(obj)
	end)
	obj.ChildRemoved:Connect(function()
		showChildren(obj)
	end)
end

local function createObjectButton(obj)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, 0, 0.15, 0)
	btn.Text = obj.Name
	btn.BackgroundColor3 = getColorByType(obj)
	btn.TextColor3 = Color3.fromRGB(0, 0, 0)
	btn.TextScaled = true
	btn.Font = Enum.Font.SourceSans
	btn.Parent = panelScroll

	local padding = Instance.new("UIPadding")
	padding.PaddingLeft = UDim.new(0.01, 0)
	padding.PaddingRight = UDim.new(0.01, 0)
	padding.PaddingTop = UDim.new(0.003, 0)
	padding.PaddingBottom = UDim.new(0.003, 0)
	padding.Parent = btn

	btn.MouseButton1Click:Connect(function()
		showObjectContents(obj)
	end)
end

local function scanWorkspace()
	-- Обновляем список объектов
	local function refreshObjectList()
		-- Очистка старых кнопок
		for _, child in pairs(panelScroll:GetChildren()) do
			if child:IsA("TextButton") then
				child:Destroy()
			end
		end
		-- Добавляем все подходящие объекты
		for _, obj in pairs(workspace:GetChildren()) do
			if obj:IsA("Part") or obj:IsA("MeshPart") or obj:IsA("UnionOperation") or obj:IsA("Model") or obj:IsA("Folder") then
				createObjectButton(obj)
			end
		end
	end

	-- Первый запуск
	refreshObjectList()

	-- Обновление при добавлении/удалении
	workspace.ChildAdded:Connect(function()
		refreshObjectList()
	end)
	workspace.ChildRemoved:Connect(function()
		refreshObjectList()
	end)
end

scanWorkspace()
