local touchDebounce = false
local touchHideVersion = 0

local function getObjectPath(obj)
	-- Строим путь от Workspace до объекта
	local path = obj.Name
	local current = obj.Parent
	while current and current ~= workspace do
		path = current.Name .. "/" .. path
		current = current.Parent
	end
	return "Workspace/" .. path
end

local function getObjectName(part)
	-- Если часть принадлежит модели, показываем название модели и путь
	local parent = part.Parent
	if parent and parent:IsA("Model") and parent ~= workspace then
		return parent.Name .. " [Model]\n" .. getObjectPath(parent)
	elseif parent and parent:IsA("Folder") and parent ~= workspace then
		return parent.Name .. " [Folder]\n" .. getObjectPath(parent)
	else
		local typeLabel = getLabelTextByType(part)
		return part.Name .. " " .. typeLabel .. "\n" .. getObjectPath(part)
	end
end

local function showTouchName(objectName)
	touchLabel.Text = objectName
	touchLabel.Visible = true

	-- Плавное появление
	touchLabel.BackgroundTransparency = 1
	touchLabel.TextTransparency = 1

	for i = 1, 10 do
		touchLabel.BackgroundTransparency = 1 - (i / 10) * 0.7
		touchLabel.TextTransparency = 1 - (i / 10)
		task.wait(0.02)
	end

	-- Сброс таймера скрытия через версию
	touchHideVersion = touchHideVersion + 1
	local currentVersion = touchHideVersion

	task.delay(2, function()
		-- Если версия изменилась, значит был новый тач — не скрываем
		if touchHideVersion ~= currentVersion then return end

		-- Плавное исчезновение
		for i = 1, 10 do
			if touchHideVersion ~= currentVersion then return end
			touchLabel.BackgroundTransparency = 0.3 + (i / 10) * 0.7
			touchLabel.TextTransparency = i / 10
			task.wait(0.02)
		end
		touchLabel.Visible = false
	end)
end

local function onPartTouched(part)
	if touchDebounce then return end

	local character = player.Character
	if not character then return end

	local hrp = character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	-- Проверяем, что коснулся именно персонаж игрока
	local touchingPart = nil
	for _, touching in part:GetTouchingParts() do
		if touching:IsDescendantOf(character) then
			touchingPart = touching
			break
		end
	end

	if not touchingPart then return end

	touchDebounce = true
	local objectName = getObjectName(part)
	showTouchName(objectName)

	task.delay(1.5, function()
		touchDebounce = false
	end)
end

local function setupTouchForPart(part)
	if part:IsA("BasePart") and not part:IsA("Terrain") then
		part.Touched:Connect(function(otherPart)
			local character = player.Character
			if not character then return end
			if otherPart:IsDescendantOf(character) then
				onPartTouched(part)
			end
		end)
	end
end

-- Подключаем касание для всех существующих частей
for _, descendant in workspace:GetDescendants() do
	setupTouchForPart(descendant)
end

-- Подключаем касание для новых частей, добавленных позже
workspace.DescendantAdded:Connect(function(descendant)
	setupTouchForPart(descendant)
end)
	-- очищаем старые кнопки
	for _, child in pairs(panelScroll:GetChildren()) do
		if child:IsA("TextButton") then
			child:Destroy()
		end
	end

	-- ищем все Part, MeshPart, Model, Folder
	for _, obj in pairs(workspace:GetChildren()) do
		if obj:IsA("Part") or obj:IsA("MeshPart") or obj:IsA("UnionOperation") or obj:IsA("Model") or obj:IsA("Folder") then
			createObjectButton(obj)
		end
	end
end

scanWorkspace()
