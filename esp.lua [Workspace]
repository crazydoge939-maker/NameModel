-- Перемещение панели
local dragging = false
local dragOffset = Vector2.new()

panel.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragOffset = Vector2.new(input.Position.X - panel.AbsolutePosition.X, input.Position.Y - panel.AbsolutePosition.Y)
	end
end)

panel.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local screenSize = workspace.CurrentCamera.ViewportSize
		local newPosX = (input.Position.X - dragOffset.X) / screenSize.X
		local newPosY = (input.Position.Y - dragOffset.Y) / screenSize.Y
		newPosX = math.clamp(newPosX, 0, 1 - panel.Size.X.Scale)
		newPosY = math.clamp(newPosY, 0, 1 - panel.Size.Y.Scale)
		panel.Position = UDim2.new(newPosX, 0, newPosY, 0)
		-- Обновляем позицию contentFrame справа от панели
		contentFrame.Position = UDim2.new(newPosX + panel.Size.X.Scale + 0.01, 0, newPosY, 0)
	end
end)

local function setContentFramePosition()
	contentFrame.Position = UDim2.new(panel.Position.X.Scale + panel.Size.X.Scale + 0.01, 0, panel.Position.Y.Scale, 0)
end

setContentFramePosition()

local function clearContent()
	for _, child in pairs(scrollFrame:GetChildren()) do
		if child:IsA("GuiObject") then
			child:Destroy()
		end
	end
end

local function getColorByType(obj)
	if obj:IsA("Part") then
		return Color3.fromRGB(160, 160, 160)
	elseif obj:IsA("MeshPart") then
		return Color3.fromRGB(80, 80, 80)
	elseif obj:IsA("UnionOperation") then
		return Color3.fromRGB(0, 255, 0)
	elseif obj:IsA("Model") then
		return Color3.fromRGB(255, 0, 255)
	elseif obj:IsA("Folder") then
		return Color3.fromRGB(255, 165, 0)
	else
		return Color3.fromRGB(0, 0, 255)
	end
end

local function getLabelTextByType(obj)
	if obj:IsA("Part") then
		return "[Part]"
	elseif obj:IsA("MeshPart") then
		return "[MeshPart]"
	elseif obj:IsA("UnionOperation") then
		return "[Union]"
	elseif obj:IsA("Model") then
		return "[Model]"
	elseif obj:IsA("Folder") then
		return "[Folder]"
	else
		return "[Object]"
	end
end

local function showObjectContents(obj)
	if currentFolderConnection then
		currentFolderConnection:Disconnect()
		currentFolderConnection = nil
	end

	clearContent()

	local function updateContent()
		clearContent()

		local children = {}
		local folderCount = {}

		for _, child in pairs(obj:GetChildren()) do
			if child:IsA("Folder") then
				folderCount[child.Name] = (folderCount[child.Name] or 0) + 1
			else
				children[child.Name] = (children[child.Name] or 0) + 1
			end
		end

		-- вывод файлов
		for name, count in pairs(children) do
			local label = Instance.new("TextLabel")
			label.Size = UDim2.new(1, 0, 0.15, 0)
			label.Text = name .. (count > 1 and (" x" .. count) or "")
			label.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
			label.TextColor3 = Color3.fromRGB(255, 255, 255)
			label.TextScaled = true
			label.TextXAlignment = Enum.TextXAlignment.Left
			label.Font = Enum.Font.SourceSans
			label.Parent = scrollFrame

			local padding = Instance.new("UIPadding")
			padding.PaddingLeft = UDim.new(0.01, 0)
			padding.PaddingRight = UDim.new(0.01, 0)
			padding.PaddingTop = UDim.new(0.003, 0)
			padding.PaddingBottom = UDim.new(0.003, 0)
			padding.Parent = label
		end

		-- вывод папок
		for name, count in pairs(folderCount) do
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1, 0, 0.15, 0)
			btn.Text = "[Folder] " .. name .. (count > 1 and (" x" .. count) or "")
			btn.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
			btn.TextColor3 = Color3.fromRGB(0, 0, 0)
			btn.TextScaled = true
			btn.Font = Enum.Font.SourceSans
			btn.Parent = scrollFrame

			local btnPadding = Instance.new("UIPadding")
			btnPadding.PaddingLeft = UDim.new(0.01, 0)
			btnPadding.PaddingRight = UDim.new(0.01, 0)
			btnPadding.PaddingTop = UDim.new(0.003, 0)
			btnPadding.PaddingBottom = UDim.new(0.003, 0)
			btnPadding.Parent = btn

			btn.MouseButton1Click:Connect(function()
				local subFolder = obj:FindFirstChild(name)
				if subFolder and subFolder:IsA("Folder") then
					showObjectContents(subFolder)
				end
			end)
		end
	end

	updateContent()

	currentFolderConnection = obj.ChildAdded:Connect(function()
		updateContent()
	end)
	obj.ChildRemoved:Connect(function()
		updateContent()
	end)
end

local function createObjectButton(obj, displayName)
	local name = displayName or obj.Name
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, 0, 0.15, 0)
	btn.Text = name
	btn.BackgroundColor3 = getColorByType(obj)
	btn.TextColor3 = Color3.fromRGB(0, 0, 0)
	btn.TextScaled = true
	btn.Font = Enum.Font.SourceSans
	btn.Parent = panelScroll

	local btnPadding = Instance.new("UIPadding")
	btnPadding.PaddingLeft = UDim.new(0.01, 0)
	btnPadding.PaddingRight = UDim.new(0.01, 0)
	btnPadding.PaddingTop = UDim.new(0.003, 0)
	btnPadding.PaddingBottom = UDim.new(0.003, 0)
	btnPadding.Parent = btn

	btn.MouseButton1Click:Connect(function()
		showObjectContents(obj)
	end)
end

